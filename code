<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sharma Public School</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            line-height: 1.6;
        }

        header {
            background: #28a745;
            color: white;
            padding: 15px;
            text-align: center;
        }

        nav {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 10px;
        }

        nav a {
            color: white;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

        nav a:hover {
            color: #d4edda;
        }

        section {
            padding: 40px 20px;
            text-align: center;
        }

        #home {
            background: #f0fff4;
        }

        #home img {
            width: 100%;
            height: 300px;
            object-fit: cover;
            border-radius: 10px;
            margin-top: 15px;
        }

        button {
            padding: 10px 20px;
            margin-top: 15px;
            border: none;
            background: #28a745;
            color: white;
            cursor: pointer;
            border-radius: 5px;
            transition: 0.3s;
        }

        button:hover {
            background: #1e7e34;
        }

        .course-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .course {
            background: #e6f4ea;
            padding: 20px;
            border-radius: 10px;
            width: 250px;
        }

        form {
            max-width: 400px;
            margin: auto;
            display: flex;
            flex-direction: column;
        }

        input, textarea {
            margin: 10px 0;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

        /* Address Styling */
        .address {
            margin-top: 15px;
            font-weight: bold;
            color: #333;
        }

        /* Footer */
        footer {
            background: #28a745;
            color: white;
            text-align: center;
            padding: 10px;
            margin-top: 20px;
        }

        @media (max-width: 600px) {
            nav {
                flex-direction: column;
            }
        }
    </style>
</head>

<body>

    <!-- Header -->
    <header>
        <h1>Sharma Public School</h1>
        <nav>
            <a href="#home">Home</a>
            <a href="#about">About</a>
            <a href="#courses">Courses</a>
            <a href="#contact">Contact</a>
        </nav>
    </header>

    <!-- Home -->
    <section id="home">
        <h2>Welcome to Sharma Public School</h2>
        <p>We provide quality education for a bright future.</p>

        <img src="https://images.unsplash.com/photo-1588072432836-e10032774350?auto=format&fit=crop&w=1200&q=80" alt="School Banner">

        <br>
        <button onclick="showWelcome()">Click Me</button>
    </section>

    <!-- About -->
    <section id="about">
        <h2>About Us</h2>
        <p>
            Sharma Public School is dedicated to providing excellent education 
            and nurturing students to achieve their full potential. 
            Our mission is to build a strong foundation for future success.
        </p>
    </section>

    <!-- Courses -->
    <section id="courses">
        <h2>Our Courses</h2>

        <div class="course-container">
            <div class="course">
                <h3>Science</h3>
                <p>Explore physics, chemistry, and biology concepts.</p>
            </div>

            <div class="course">
                <h3>Mathematics</h3>
                <p>Build strong problem-solving and analytical skills.</p>
            </div>

            <div class="course">
                <h3>Computer</h3>
                <p>Learn programming and modern technology basics.</p>
            </div>
        </div>
    </section>

    <!-- Contact -->
    <section id="contact">
        <h2>Contact Us</h2>

        <form onsubmit="return validateForm()">
            <input type="text" id="name" placeholder="Enter your name">
            <input type="email" id="email" placeholder="Enter your email">
            <textarea id="message" rows="5" placeholder="Enter your message"></textarea>

            <button type="submit">Submit</button>
        </form>

        <!-- Address Added -->
        <p class="address">Address: Palwal, Haryana</p>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2026 Sharma Public School | Palwal, Haryana</p>
    </footer>

    <!-- JavaScript -->
    <script>
        function showWelcome() {
            alert("Welcome to Sharma Public School!");
        }

        function validateForm() {
            let name = document.getElementById("name").value;
            let email = document.getElementById("email").value;
            let message = document.getElementById("message").value;

            if (name === "" || email === "" || message === "") {
                alert("Please fill all fields!");
                return false;
            }

            let emailPattern = /^[^ ]+@[^ ]+\.[a-z]{2,3}$/;
            if (!email.match(emailPattern)) {
                alert("Please enter a valid email!");
                return false;
            }

            alert("Form submitted successfully!");
            return true;
        }
    </script>

</body>
</html>
